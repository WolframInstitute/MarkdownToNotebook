QuantumCircuitOperator[{"CNOT", 
   QuantumCircuitOperator[{QuantumOperator["SWAP", {2, 4}], 
     QuantumOperator[{"Phase", \[Gamma]}]}, "MyCir"]}]["Diagram"]
